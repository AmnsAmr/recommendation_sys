    ++++ pom.xml
    +++ user-service/                   | Spring Boot -- port 8081
    ++++ src/main/java/org/vidrec/userservice/
    +++++ user/
    +++++ admin/
    +++++ preference/
    +++++ event/
    +++++ kafka/
    +++++ security/
    +++++ config/
    ++++ src/main/resources/
    +++++ application.properties
    ++++ pom.xml
    +++ video-service/                  | Spring Boot -- port 8082
    ++++ src/main/java/org/vidrec/videoservice/
    +++++ video/
    +++++ admin/
    +++++ watch/
    +++++ catalog/
    +++++ youtube/
    +++++ storage/
    +++++ kafka/
    +++++ outbox/
    +++++ config/
    ++++ src/main/resources/
    +++++ application.properties
    ++++ pom.xml
    +++ recommendation-service/         | Spring Boot -- port 8083
    ++++ src/main/java/org/vidrec/recommendationservice/
    +++++ recommendation/
    +++++ interaction/
    +++++ model/
    +++++ content/
    +++++ cache/
    +++++ kafka/
    +++++ config/
    ++++ src/main/resources/
    +++++ application.properties
