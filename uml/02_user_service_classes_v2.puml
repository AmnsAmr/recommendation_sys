@startuml User Service -- Class Diagram (v2)
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam ClassBorderColor #888888
skinparam ClassBackgroundColor #F8F8F8

title User Service -- Class Diagram (v2)

package "user-service" {

  package "kafka" {
    class UserEventPublisher {
      - kafkaTemplate: KafkaTemplate<String, Object>
      + publishUserRegistered(event: UserRegisteredEvent): void
      + publishUserDeactivated(event: UserDeactivatedEvent): void
      + publishPreferencesUpdated(event: UserPreferencesUpdatedEvent): void
    }
  }

  package "model" {
    class User {
      - id: UUID
      - email: String
      - passwordHash: String
      - username: String
      - displayName: String
      - role: UserRole
      - bio: String
      - profilePictureUrl: String
      - isActive: boolean
      - bannedAt: LocalDateTime
      - banReason: String
      - createdAt: LocalDateTime
      - updatedAt: LocalDateTime
      + getId(): UUID
      + getEmail(): String
      + isActive(): boolean
    }

    enum UserRole {
      USER
      ADMIN
    }

    class UserPreference {
      - id: UUID
      - userId: UUID
      - category: String
      - weight: Double
      - createdAt: LocalDateTime
      - updatedAt: LocalDateTime
    }

    User "1" --> "many" UserPreference : has
  }

  package "dto" {
    class RegisterRequest {
      + email: String
      + password: String
      + username: String
      + displayName: String
      + interests: List<String>
    }

    class LoginRequest {
      + email: String
      + password: String
    }

    class AuthResponse {
      + token: String
      + userId: UUID
      + username: String
      + role: String
      + expiresIn: Long
    }

    class UserProfileResponse {
      + userId: UUID
      + username: String
      + displayName: String
      + bio: String
      + profilePictureUrl: String
      + preferences: List<PreferenceDTO>
      + role: String
      + createdAt: LocalDateTime
    }

    class UpdateProfileRequest {
      + displayName: String
      + bio: String
      + profilePictureUrl: String
    }

    class PreferenceDTO {
      + category: String
      + weight: Double
    }
  }

  package "event" {
    class UserRegisteredEvent {
      + eventId: UUID
      + userId: UUID
      + username: String
      + interests: List<String>
      + timestamp: Instant
    }

    class UserDeactivatedEvent {
      + eventId: UUID
      + userId: UUID
      + timestamp: Instant
    }

    class UserPreferencesUpdatedEvent {
      + eventId: UUID
      + userId: UUID
      + preferences: List<String>
      + timestamp: Instant
    }
  }

  package "controller" {
    class UserController {
      - userService: UserService
      + register(request: RegisterRequest): ResponseEntity<AuthResponse>
      + login(request: LoginRequest): ResponseEntity<AuthResponse>
      + getProfile(userId: UUID): ResponseEntity<UserProfileResponse>
      + updateProfile(userId: UUID, request: UpdateProfileRequest): ResponseEntity<UserProfileResponse>
      + updatePreferences(userId: UUID, prefs: List<PreferenceDTO>): ResponseEntity<UserProfileResponse>
    }
  }

  package "admin" {
    class AdminUserController {
      - adminUserService: AdminUserService
      + getDashboard(): ResponseEntity<AdminDashboardResponse>
      + listUsers(page: int, size: int): ResponseEntity<Page<AdminUserSummaryResponse>>
      + getUser(userId: UUID): ResponseEntity<AdminUserDetailResponse>
      + updateUser(userId: UUID, request: AdminUpdateUserRequest): ResponseEntity<AdminUserDetailResponse>
      + banUser(userId: UUID, request: AdminBanUserRequest): ResponseEntity<AdminUserDetailResponse>
      + unbanUser(userId: UUID): ResponseEntity<AdminUserDetailResponse>
      + deleteUser(userId: UUID): ResponseEntity<Void>
    }

    class AdminUserService {
      - userRepository: UserRepository
      - preferenceRepository: UserPreferenceRepository
      - eventPublisher: UserEventPublisher
      + getDashboard(): AdminDashboardResponse
      + listUsers(page: int, size: int): Page<AdminUserSummaryResponse>
      + getUser(userId: UUID): AdminUserDetailResponse
      + updateUser(userId: UUID, request: AdminUpdateUserRequest): AdminUserDetailResponse
      + banUser(userId: UUID, request: AdminBanUserRequest): AdminUserDetailResponse
      + unbanUser(userId: UUID): AdminUserDetailResponse
      + deleteUser(userId: UUID): void
    }

    class AdminDashboardResponse {
      + totalUsers: long
      + activeUsers: long
      + bannedUsers: long
      + adminUsers: long
      + newUsersLast7Days: long
    }

    class AdminUserSummaryResponse {
      + userId: UUID
      + email: String
      + username: String
      + displayName: String
      + role: String
      + isActive: boolean
      + bannedAt: LocalDateTime
      + createdAt: LocalDateTime
    }

    class AdminUserDetailResponse {
      + userId: UUID
      + email: String
      + username: String
      + displayName: String
      + role: String
      + isActive: boolean
      + banReason: String
      + preferences: List<PreferenceDTO>
      + createdAt: LocalDateTime
      + updatedAt: LocalDateTime
    }

    class AdminUpdateUserRequest {
      + displayName: String
      + bio: String
      + profilePictureUrl: String
      + role: String
    }

    class AdminBanUserRequest {
      + reason: String
    }
  }

  package "service" {
    class UserService {
      - userRepository: UserRepository
      - preferenceRepository: UserPreferenceRepository
      - jwtUtil: JwtUtil
      - passwordEncoder: PasswordEncoder
      - eventPublisher: UserEventPublisher
      + register(request: RegisterRequest): AuthResponse
      + login(request: LoginRequest): AuthResponse
      + getUserById(id: UUID): User
      + updateProfile(userId: UUID, request: UpdateProfileRequest): User
      + updatePreferences(userId: UUID, prefs: List<PreferenceDTO>): void
      + deactivateUser(userId: UUID): void
    }
  }

  package "repository" {
    interface UserRepository {
      + findByEmail(email: String): Optional<User>
      + findById(id: UUID): Optional<User>
      + findByUsername(username: String): Optional<User>
      + existsByEmail(email: String): boolean
    }

    interface UserPreferenceRepository {
      + findByUserId(userId: UUID): List<UserPreference>
      + deleteByUserId(userId: UUID): void
    }
  }

  package "security" {
    class JwtUtil {
      - secret: String
      - expiration: Long
      + generateToken(userId: UUID, role: String): String
      + validateToken(token: String): boolean
      + extractUserId(token: String): UUID
      + extractRole(token: String): String
    }
  }

  UserController --> UserService
  AdminUserController --> AdminUserService
  AdminUserService --> UserRepository
  AdminUserService --> UserPreferenceRepository
  AdminUserService --> UserEventPublisher
  UserService --> UserRepository
  UserService --> UserPreferenceRepository
  UserService --> JwtUtil
  UserService --> UserEventPublisher
}

note bottom of User
  v2 changes:
  + displayName (shown publicly, different from username)
  + role (USER / ADMIN)
  + bio (short user description)
  + profilePictureUrl (URL to avatar image)
  + isActive (account active flag)
  + bannedAt / banReason (admin moderation)
  + updatedAt (track profile edits)
  + Register now accepts initial interests
end note

note bottom of UserService
  User events are published after commit:
  user.events with eventType:
  registered, deactivated,
  prefs_updated, banned, deleted.
end note

@enduml
