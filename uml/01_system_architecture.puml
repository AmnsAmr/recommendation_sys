@startuml System_Architecture
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam ArrowColor #555555
skinparam componentBorderColor #888888

title Video Platform -- System Architecture

actor "User" as user
actor "Admin" as admin

package "Frontend" {
  [Next.js / React + TypeScript\nport 3000] as frontend
}

package "Backend -- Spring Boot Microservices" {
  [API Gateway\nSpring Cloud Gateway\nport 8080] as gateway

  [User Service\nport 8081] as userSvc
  [Video Service\nport 8082] as videoSvc
  [Recommendation Service\nport 8083] as recSvc
}

package "ML Sidecar" {
  [SVD Sidecar\nFastAPI\nport 8000] as svdSidecar
}

package "Kafka / Aiven" {
  queue "Kafka Topics\nvideo.watched\nvideo.liked\nuser.searched\nvideo.uploaded\nuser.events" as kafka
}

package "Storage" {
  database "User DB\nPostgreSQL / Supabase" as userDb
  database "Video DB\nPostgreSQL / Supabase" as videoDb
  database "Rec DB\nPostgreSQL / Supabase" as recDb
  [Redis Cache\npre-computed recs] as redis
  [S3 / Cloudflare R2\nvideo files] as s3
}

package "External" {
  [YouTube Data API v3] as ytApi
}

user --> frontend : HTTP
admin --> frontend : admin HTTP
frontend --> gateway : REST / HTTPS
gateway --> userSvc : route /users/**
gateway --> videoSvc : route /videos/**
gateway --> recSvc : route /recommendations/**
gateway --> userSvc : route /admin/users/**
gateway --> videoSvc : route /admin/videos/**

note right of gateway
  Trust boundary: services only accept
  requests from the gateway and verify
  an internal auth signal (X-Internal-Token
  or mTLS). Gateway forwards X-User-Id
  and X-User-Role. Direct service ports
  are not exposed.
end note

userSvc --> userDb
videoSvc --> videoDb
videoSvc --> s3 : upload/stream
videoSvc --> ytApi : fetch catalog
recSvc --> recDb
recSvc --> redis : cache results
recSvc --> svdSidecar : SVD train/predict\nHTTP internal

videoSvc --> kafka : publishes events
userSvc --> kafka : publishes events
kafka --> recSvc : consumes all topics

note bottom of videoSvc
  Platform uploads remain private until
  an admin approves them. Only approved
  videos emit video.uploaded and become public.
end note

note bottom of frontend
  Admin dashboard aggregates service-local
  metrics from /admin/users/dashboard and
  /admin/videos/dashboard.
end note

@enduml
