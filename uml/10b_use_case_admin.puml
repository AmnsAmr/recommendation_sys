@startuml Cas_d_utilisation_Administrateur
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam usecaseBackgroundColor #FAFAFA
skinparam usecaseBorderColor #555555
skinparam actorBorderColor #333333
left to right direction

title Diagramme de cas d'utilisation -- Côté Administrateur

' --- Actor hierarchy: Administrateur inherits from Utilisateur ---
:Visiteur:    as visiteur
:Administrateur: as admin
admin --|> visiteur

rectangle "Plateforme Vidéo -- Modération & Administration" {

  usecase "Se connecter" as UC_Login

  ' --- Moderation ---
  usecase "Modérer les vidéos" as UC_Moderate
  usecase "Approuver"          as UC_Approve
  usecase "Rejeter"            as UC_Reject

  ' --- User management ---
  usecase "Gérer les utilisateurs"   as UC_ManageUsers
  usecase "Bannir un utilisateur"    as UC_Ban
  usecase "Réactiver un utilisateur" as UC_Reactivate

  ' --- Supervision ---
  usecase "Consulter le\ntableau de bord" as UC_Dashboard
  usecase "Superviser le\nsystème"        as UC_Supervise
}

' --- Associations ---
admin -- UC_Moderate
admin -- UC_ManageUsers
admin -- UC_Dashboard
admin -- UC_Supervise

visiteur -- UC_Login

' --- «include» ---
' Each top-level admin use case includes Login.
' Use cases that <<extend>> a base UC do NOT include Login (inherited via base).
UC_Moderate    ..> UC_Login : <<include>>
UC_ManageUsers ..> UC_Login : <<include>>
UC_Dashboard   ..> UC_Login : <<include>>
UC_Supervise   ..> UC_Login : <<include>>

' --- «extend» (optional admin actions) ---
UC_Approve    ..> UC_Moderate    : <<extend>>
UC_Reject     ..> UC_Moderate    : <<extend>>
UC_Ban        ..> UC_ManageUsers : <<extend>>
UC_Reactivate ..> UC_ManageUsers : <<extend>>

' --- NFRs as notes ---
note top of UC_Moderate
  Toute vidéo téléversée reste
  privée jusqu'à approbation
  par un administrateur
end note
note right of UC_Supervise
  Disponibilité cible 99.9%
  Capacité 10 000 transactions
  simultanées
end note
@enduml