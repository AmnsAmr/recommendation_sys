@startuml Diagramme_de_classes
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam ClassBorderColor #555555
skinparam ClassBackgroundColor #F8F8F8
skinparam PackageBorderColor #888888

title Diagramme de classes -- Plateforme Vidéo

' ============================================================
' ENUMERATIONS (PPT rule CD9)
' ============================================================
enum "«Enumeration»\nRôle" as ERole {
  UTILISATEUR
  ADMINISTRATEUR
}
enum "«Enumeration»\nStatutVidéo" as EStatus {
  EN_ATTENTE
  EN_REVUE
  PUBLIÉE
  REJETÉE
}
enum "«Enumeration»\nOrigineVidéo" as ESource {
  PLATEFORME
  YOUTUBE
}
enum "«Enumeration»\nLangue" as ELang {
  FR
  EN
  ES
  AR
}
enum "«Enumeration»\nTypeAppréciation" as EAction {
  AIMÉE
  NON_AIMÉE
}
enum "«Enumeration»\nTypeInteraction" as EEvent {
  VISIONNAGE
  APPRÉCIATION
  REVISIONNAGE
  CLIC_RECHERCHE
}
enum "«Enumeration»\nOrigineProfil" as EProfSrc {
  DÉCLARÉ
  INFÉRÉ
}

' ============================================================
' SUBSYSTEM: GestionUtilisateurs
' ============================================================
package "«SousSystème» GestionUtilisateurs" as PkgUser {

  class Utilisateur {
    - identifiant : UUID [1]
    - email : String [1]
    - motDePasse : String [1]
    - pseudo : String [1]
    - nomAffiché : String [1]
    - biographie : String [0..1]
    - urlPhoto : String [0..1]
    - actif : Booléen [1]
    - dateInscription : Date [1]
    --
    + S_inscrire( in email : String [1], in motDePasse : String [1], in pseudo : String [1], in intérêts : String [1..*] )
    + Se_connecter( in email : String [1], in motDePasse : String [1] ) : Jeton
    + Modifier_profil( in biographie : String [0..1], in urlPhoto : String [0..1] )
    + Consulter_profil() : Utilisateur
    + Se_déconnecter()
    + Publier_vidéo( in titre : String [1], in description : String [0..1], in fichier : Fichier [1], in catégorie : Catégorie [1] ) : Vidéo
    + Consulter_mes_vidéos() : Vidéo [*]
  }

  class Administrateur {
    --
    + Modérer_vidéo( in vidéo : Vidéo [1], in décision : StatutVidéo [1] )
    + Bannir_utilisateur( in utilisateur : Utilisateur [1], in motif : String [1] )
    + Consulter_tableau_de_bord() : TableauDeBord
    + Gérer_utilisateurs()
  }

  class PréférenceUtilisateur {
    - catégorie : String [1]
    - poids : Réel [1]
    - source : OrigineProfil [1]
    --
    + Mettre_à_jour( in poids : Réel [1] )
  }

  Administrateur --|> Utilisateur
  Utilisateur "1" *-- "1..*" PréférenceUtilisateur : possède
}

' ============================================================
' SUBSYSTEM: GestionVidéos
' ============================================================
package "«SousSystème» GestionVidéos" as PkgVideo {

  class Vidéo {
    - identifiant : String [1]
    - titre : String [1]
    - description : String [0..1]
    - durée : Entier [1]
    - urlMiniature : String [1]
    - nombreVues : Entier [1]
    - nombreAppréciations : Entier [1]
    - datePublication : Date [0..1]
    --
    + Lire() : Flux
    + Incrémenter_vues()
    + Approuver( in administrateur : Administrateur [1] )
    + Rejeter( in administrateur : Administrateur [1], in motif : String [1] )
    + Rechercher( in requête : String [1] ) : Vidéo [*]
  }

  class Catégorie {
    - identifiant : String [1]
    - nom : String [1]
    --
    + Lister_vidéos() : Vidéo [*]
  }

  class Étiquette {
    - libellé : String [1]
  }

  class SessionVisionnage {
    - identifiant : UUID [1]
    - durée : Entier [1]
    - pourcentageComplété : Réel [1]
    - nombreRevisionnages : Entier [1]
    - date : Date [1]
    --
    + Enregistrer()
    + Calculer_score() : Réel
  }

  class Appréciation {
    - type : TypeAppréciation [1]
    - date : Date [1]
    --
    + Enregistrer()
  }

  Vidéo "1" *-- "1..*" Étiquette         : étiquettée par
  Vidéo "*" o-- "1"    Catégorie         : classée dans
  Vidéo "1" *-- "*"    SessionVisionnage : tracée par
  Vidéo "1" *-- "*"    Appréciation      : appréciée par
}

' ============================================================
' SUBSYSTEM: Recommandation
' ============================================================
package "«SousSystème» Recommandation" as PkgReco {

  class Interaction {
    - identifiant : UUID [1]
    - type : TypeInteraction [1]
    - score : Réel [1]
    - date : Date [1]
  }

  class ProfilUtilisateur {
    - vecteur : Réel [*]
    - nombreInteractions : Entier [1]
    - dateMiseÀJour : Date [1]
    --
    + Recalculer()
  }

  class ProfilVidéo {
    - vecteur : Réel [*]
    - scoreGlobal : Réel [1]
    --
    + Recalculer()
  }

  class MoteurRecommandation {
    --
    + Générer_recommandations( in utilisateur : Utilisateur [1], in limite : Entier [1] ) : Vidéo [*]
    + Vidéos_similaires( in vidéo : Vidéo [1], in limite : Entier [1] ) : Vidéo [*]
    + Démarrage_à_froid( in catégorie : Catégorie [1], in limite : Entier [1] ) : Vidéo [*]
  }

  ProfilUtilisateur "1" *-- "*" Interaction : agrège
  MoteurRecommandation ..> ProfilUtilisateur : <<use>>
  MoteurRecommandation ..> ProfilVidéo       : <<use>>
}

' ============================================================
' Cross-subsystem relationships
' ============================================================
Utilisateur "1" -- "*" Vidéo             : publie
Utilisateur "1" -- "*" SessionVisionnage : réalise
Utilisateur "1" -- "*" Appréciation      : émet
Utilisateur "1" -- "1" ProfilUtilisateur : décrit par
Vidéo       "1" -- "1" ProfilVidéo       : indexée par
Interaction "*" -- "1" Vidéo             : cible

' ============================================================
' NFRs as {constraints} on the responsible class (PPT rule CD11)
' ============================================================
class Plateforme <<SupervisionSystème>> {
  {Disponibilité = 99.9%}
  {TransactionsSimultanées = 10000}
  --
  + Superviser_santé() : Booléen
  + Mettre_à_l_échelle()
}

Plateforme ..> MoteurRecommandation : <<use>>
Plateforme ..> Vidéo                : <<use>>

note bottom of PkgReco
  Les stéréotypes «SousSystème», «SupervisionSystème»
  et «Enumeration» sont définis dans le diagramme de
  profil (voir 15_profile_diagram.puml).
end note
@enduml